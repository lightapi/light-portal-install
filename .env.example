# Light Portal local install defaults.
#
# Copy to .env only when overriding values. install.sh downloads the current
# docker-images.env from R2 and merges it with local overrides.

LIGHT_PORTAL_VERSION=latest
LIGHT_PORTAL_ASSET_BASE_URL=https://cdn.networknt.com
LIGHT_PORTAL_RELEASE_BASE_URL=https://cdn.networknt.com/light-portal/releases

LIGHT_GATEWAY_HOST_PORT=443
LIGHT_AGENT_PORT=8083
PORTAL_DATA_DIR=./data

RUST_LOG=debug
LIGHT_AGENT_RUST_LOG=info
CODEX_API_KEY=
CODEX_ACCOUNT_ID=
LIGHT_AGENT_AGENT_DEF_ID=
LIGHT_AGENT_MODEL=gpt-5.5
LIGHT_AGENT_TEMPERATURE=0.7
CODEX_REASONING_EFFORT=low

NOREPLAY_EMAIL_PASSWORD=
STATELESSAUTH_BOOTSTRAPTOKEN=
STATELESSAUTH_GITHUBCLIENTSECRET=
STATELESSAUTH_GOOGLECLIENTSECRET=
STATELESSAUTH_FACEBOOKCLIENTSECRET=

EMBEDDING_TASK_ENABLED=false
EMBEDDING_TASK_PROVIDER=disabled
EMBEDDING_TASK_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai/embeddings
EMBEDDING_TASK_MODEL=gemini-embedding-001
EMBEDDING_TASK_DIMENSION=384
GEMINI_API_KEY=

# Shared by hybrid-command and hybrid-query. Populate from a secret manager.
INSTANCE_CLONE_PLAN_HMAC_KEY=
INSTANCE_CLONE_PLAN_HMAC_KEY_ID=v1
